{
  "_comment": "Example board config for the claude-home repo itself. Copy to config/boards/ and fill in your Linear team details.",
  "teamId": "YOUR_LINEAR_TEAM_UUID",
  "name": "YourTeam",
  "ticketPrefix": "TEAM",
  "ticketSystem": "linear",
  "states": {
    "backlog":     "YOUR_BACKLOG_STATE_UUID",
    "todo":        "YOUR_TODO_STATE_UUID",
    "inProgress":  "YOUR_IN_PROGRESS_STATE_UUID",
    "humanReview": "YOUR_HUMAN_REVIEW_STATE_UUID",
    "inReview":    "YOUR_IN_REVIEW_STATE_UUID",
    "rework":      "YOUR_REWORK_STATE_UUID",
    "merging":     "YOUR_MERGING_STATE_UUID",
    "done":        "YOUR_DONE_STATE_UUID"
  },
  "defaultRepo": "claude-home",
  "repos": [
    {
      "name": "claude-home",
      "description": "Claude Code personal config repo — global instructions, Symphony autonomous agent system, and shared skills. Lives at ~ (home directory).",
      "path": "~",
      "worktreesDir": "~/worktrees/claude-home",
      "defaultBranch": "main",
      "github": "YOUR_USERNAME/claude-home",
      "isMono": false,
      "code-review-comment": "",
      "setup": {
        "symlinkNodeModules": false,
        "installCommand": "cd ~/symphony && npm install",
        "installCheck": "symphony/package.json"
      }
    }
  ],
  "projects": [
    {
      "linearProjectId": "YOUR_SYMPHONY_PROJECT_UUID",
      "name": "Symphony",
      "primaryRepo": "claude-home",
      "repos": [
        {
          "name": "claude-home",
          "path": "~",
          "hint": "Claude Code config and Symphony agent system — all claude-home repo changes live here"
        }
      ]
    }
  ]
}
