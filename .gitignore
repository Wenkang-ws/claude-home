# Ignore everything by default
*

# Root exceptions
!.gitignore

# .claude config directory — subdirectory .gitignore handles runtime exclusions
!.claude/
!.claude/**

# symphony automation — symphony/.gitignore handles runtime exclusions
!symphony/
!symphony/**
# Local overrides are machine-specific and must not be committed
symphony/config/boards/*.local.json
symphony/config/symphony.local.json
