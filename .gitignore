# Ignore everything by default
*

# Root exceptions
!.gitignore
!README.md
!CLAUDE.md
!WORKFLOW.md

# GitHub Actions workflows
!.github/
!.github/workflows/
!.github/workflows/**

# .claude config directory — subdirectory .gitignore handles runtime exclusions
!.claude/
!.claude/**

# presentations / slide decks
!ppt/
!ppt/**

# symphony automation — symphony/.gitignore handles runtime exclusions
!symphony/
!symphony/**
# Personal config is machine-specific and must not be committed
symphony/config/
symphony/config/**
